  "type": "module",
  "main": "dist/agent/index.js",
  "scripts": {
    "dev": "tsx watch src/agent/index.ts",
    "dev:groq": "tsx watch src/agent/index-groq.ts",
    "cli": "tsx src/cli/demo.ts",
