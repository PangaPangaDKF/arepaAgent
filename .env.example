# ── Wallet (choose one) ────────────────────────────────────────────────────────
# WDK_SEED: BIP-39 mnemonic (12 or 24 words) — WDK-compatible, preferred
# Uses standard BIP-44 path m/44'/60'/0'/0/0 (same as MetaMask, WDK, Ledger)
WDK_SEED=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# PRIVATE_KEY: raw hex private key — fallback if WDK_SEED not set
# PRIVATE_KEY=0x_your_private_key_here

# ── ArepaPay L1 ────────────────────────────────────────────────────────────────
RPC_URL=http://127.0.0.1:9650/ext/bc/24KtPXNgmHT2vVUPK1rx72ykjKwHBdfGrQr5bwJxmuaEBm5Fpx/rpc
CHAIN_ID=13370

# ── AI API (elige uno) ─────────────────────────────────────────────────────────
# Anthropic (npm run dev) — $5 free credit en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Groq (npm run dev:groq) — GRATIS en console.groq.com, sin tarjeta
GROQ_API_KEY=gsk_...

# Sin API key (npm run cli) — acceso directo a contratos, sin IA

# ── Demo server ────────────────────────────────────────────────────────────────
PORT=3000
X402_DEMO_SERVER=http://localhost:3000
